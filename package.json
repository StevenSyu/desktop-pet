{
  "name": "desktop-notify",
  "version": "1.0.2-beta.3",
  "description": "A desktop pet notification companion for AI coding agents.",
  "author": {
    "name": "StevenSyu",
    "email": "stevenHsu@jrsys.com.tw"
  },
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "test": "vitest run",
    "e2e": "node scripts/e2e-smoke.mjs",
    "hooks:config": "node hooks/print-config.mjs",
    "hooks:codex-config": "node hooks/print-codex-config.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@preact/signals": "^2.9.1",
    "@types/node": "^25.9.1",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "jsdom": "^29.1.1",
    "playwright-core": "^1.60.0",
    "preact": "^10.29.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}
